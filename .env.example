# Ports (nginx proxies to these)
SERVER_PORT=7770
PORT=7771

# Database
DATABASE_URL=mysql://user:password@localhost:3306/bwitek

# Auth (generate secret: openssl rand -hex 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.bwitek.dev
REGISTRATION_ENABLED=false

# CORS — frontend origin allowed by the backend
CORS_ORIGIN=https://bwitek.dev

# Feature flags
NEWSLETTER_ENABLED=false

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=

# Brevo (only needed when NEWSLETTER_ENABLED=true)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=BWitek.dev
BREVO_PL_LIST_ID=
BREVO_EN_LIST_ID=
BREVO_CONTACTS_LIMIT=100
NEWSLETTER_COMPANY_ADDRESS_PL=
NEWSLETTER_COMPANY_ADDRESS_EN=

# Next.js public vars
NEXT_PUBLIC_SERVER_URL=https://api.bwitek.dev
NEXT_PUBLIC_SITE_URL=https://bwitek.dev
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
ALLOWED_DEV_ORIGINS=localhost,127.0.0.1

# Umami Analytics (optional)
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_ID=
