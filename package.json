{
  "name": "bwitek",
  "version": "0.0.1",
  "author": "Bogusław Witek",
  "devDependencies": {
    "turbo": "^2.8.17",
    "vitest": "^4.1.0"
  },
  "license": "GPL-3.0-only",
  "packageManager": "bun@1.2.13",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:server": "turbo build -F server",
    "build:web": "turbo build -F web",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F server db:push",
    "db:studio": "turbo -F server db:studio",
    "db:generate": "turbo -F server db:generate",
    "db:migrate": "turbo -F server db:migrate",
    "test": "turbo test",
    "test:web": "turbo -F web test",
    "test:server": "turbo -F server test"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@trpc/client": "^11.12.1",
      "@trpc/server": "^11.12.1",
      "better-auth": "^1.5.5",
      "dotenv": "^17.3.1",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "unrs-resolver"
  ]
}
