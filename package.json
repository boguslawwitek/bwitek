{
  "name": "bwitek",
  "version": "0.0.1",
  "author": "Bogusław Witek",
  "devDependencies": {
    "turbo": "^2.8.17",
    "vitest": "^4.1.0"
  },
  "license": "GPL-3.0-only",
  "packageManager": "bun@1.2.13",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:server": "turbo build -F server",
    "build:web": "turbo build -F web",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F server db:push",
    "db:studio": "turbo -F server db:studio",
    "db:generate": "turbo -F server db:generate",
    "db:migrate": "turbo -F server db:migrate",
    "test": "turbo test",
    "test:web": "turbo -F web test",
    "test:server": "turbo -F server test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "unrs-resolver"
  ]
}
